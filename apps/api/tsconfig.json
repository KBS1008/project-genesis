{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "dist",
    "declaration": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../../src/**/*.ts"],
  "exclude": ["node_modules", "dist", "../../src/**/*.test.ts", "src/**/*.test.ts"]
}
