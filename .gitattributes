###############################################################################
# Project Genesis
# Git Attributes
###############################################################################

# ---------------------------------------------------------------------------
# Default text handling
# ---------------------------------------------------------------------------

* text=auto eol=lf

# ---------------------------------------------------------------------------
# Source Code
# ---------------------------------------------------------------------------

*.ts      text
*.tsx     text
*.js      text
*.mjs     text
*.cjs     text

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

*.json    text
*.jsonc   text
*.yml     text
*.yaml    text
*.toml    text
*.ini     text
*.cfg     text
*.conf    text
.editorconfig text

# ---------------------------------------------------------------------------
# Documentation
# ---------------------------------------------------------------------------

*.md      text diff=markdown
LICENSE   text

# ---------------------------------------------------------------------------
# Web
# ---------------------------------------------------------------------------

*.html    text
*.css     text
*.scss    text

# ---------------------------------------------------------------------------
# Scripts
# ---------------------------------------------------------------------------

*.sh      text eol=lf
*.ps1     text eol=crlf
*.bat     text eol=crlf

# ---------------------------------------------------------------------------
# Schemas
# ---------------------------------------------------------------------------

*.schema.json text

# ---------------------------------------------------------------------------
# Game Content
# ---------------------------------------------------------------------------

game-content/** text
mods/**         text
config/**       text

# ---------------------------------------------------------------------------
# Images
# ---------------------------------------------------------------------------

*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.svg     text

# ---------------------------------------------------------------------------
# Audio
# ---------------------------------------------------------------------------

*.wav     binary
*.mp3     binary
*.ogg     binary
*.flac    binary

# ---------------------------------------------------------------------------
# Video
# ---------------------------------------------------------------------------

*.mp4     binary
*.webm    binary

# ---------------------------------------------------------------------------
# Fonts
# ---------------------------------------------------------------------------

*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary

# ---------------------------------------------------------------------------
# Archives
# ---------------------------------------------------------------------------

*.zip     binary
*.7z      binary
*.gz      binary
*.rar     binary

# ---------------------------------------------------------------------------
# Build Artifacts
# ---------------------------------------------------------------------------

*.exe     binary
*.dll     binary
*.so      binary
*.dylib   binary

# ---------------------------------------------------------------------------
# Savegames (future)
# ---------------------------------------------------------------------------

*.save    binary

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------

*.log     text