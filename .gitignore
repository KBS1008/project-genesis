###############################################################################
# Project Genesis
# Git Ignore
###############################################################################

# ============================================================================
# Dependencies
# ============================================================================

node_modules/

# ============================================================================
# Build Output
# ============================================================================

dist/
build/
coverage/
apps/web/.next/

*.tsbuildinfo

# ============================================================================
# Logs
# ============================================================================

logs/*
!logs/.gitkeep

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================================
# Runtime Files
# ============================================================================

tmp/
temp/
.cache/

# ============================================================================
# Savegames
# ============================================================================

savegames/*
!savegames/.gitkeep

# ============================================================================
# Mods (local development)
# ============================================================================

mods/*
!mods/.gitkeep

# ============================================================================
# Generated Content
# ============================================================================

generated/

# ============================================================================
# Environment Files
# ============================================================================

.env
.env.*
!.env.example

# ============================================================================
# IDE
# ============================================================================

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

.idea/

*.iml

# ============================================================================
# Operating System
# ============================================================================

.DS_Store
Thumbs.db
Desktop.ini

# ============================================================================
# Testing
# ============================================================================

.nyc_output/

# ============================================================================
# ESLint
# ============================================================================

.eslintcache

# ============================================================================
# Prettier
# ============================================================================

.prettier-cache/

# ============================================================================
# Vitest
# ============================================================================

vitest.workspace.ts.timestamp*

# ============================================================================
# Playwright (future)
# ============================================================================

playwright-report/
test-results/

# ============================================================================
# Temporary Files
# ============================================================================

*.tmp
*.temp
*.bak
*.swp
*.swo

# ============================================================================
# Archives
# ============================================================================

*.zip
*.7z

# ============================================================================
# Local Configuration
# ============================================================================

config/local.*

# ============================================================================
# Keep Empty Directories
# ============================================================================

!mods/.gitkeep
!logs/.gitkeep
!savegames/.gitkeep