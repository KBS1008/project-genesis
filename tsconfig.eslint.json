{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "tools/**/*.ts",
    "apps/api/src/**/*.ts",
    "apps/web/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["dist", "coverage", "node_modules", "apps/web/.next"]
}
