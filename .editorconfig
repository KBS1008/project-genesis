# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# https://editorconfig.org/

root = true

# -------------------------------------------------------------------
# Default settings
# -------------------------------------------------------------------

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# -------------------------------------------------------------------
# Markdown
# -------------------------------------------------------------------

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# -------------------------------------------------------------------
# TypeScript / JavaScript
# -------------------------------------------------------------------

[*.{ts,tsx,js,mjs,cjs}]
indent_size = 2

# -------------------------------------------------------------------
# JSON / JSON Schema
# -------------------------------------------------------------------

[*.{json,jsonc}]
indent_size = 2

# -------------------------------------------------------------------
# YAML
# -------------------------------------------------------------------

[*.{yml,yaml}]
indent_size = 2

# -------------------------------------------------------------------
# XML
# -------------------------------------------------------------------

[*.xml]
indent_size = 2

# -------------------------------------------------------------------
# HTML / CSS
# -------------------------------------------------------------------

[*.{html,css,scss}]
indent_size = 2

# -------------------------------------------------------------------
# Shell Scripts
# -------------------------------------------------------------------

[*.sh]
end_of_line = lf

# -------------------------------------------------------------------
# Windows Batch
# -------------------------------------------------------------------

[*.bat]
end_of_line = crlf

# -------------------------------------------------------------------
# PowerShell
# -------------------------------------------------------------------

[*.ps1]
end_of_line = crlf

# -------------------------------------------------------------------
# GitHub Actions
# -------------------------------------------------------------------

[.github/workflows/*.yml]
indent_size = 2